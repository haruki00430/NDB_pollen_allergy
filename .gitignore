# GitHub 単一ファイル 100MB 制限（大きいジオデータは LFS かローカルのみ）
*.geojson
*.shp
*.dbf
*.shx
*.prj

# 大容量アーカイブ・生データ（再ダウンロードで再現）
*.zip
*.7z
*.pkl

# 国土数値情報など数百 MB 超（GitHub 100MB 制限）
data/raw/MLIT_N03/
**/MLIT_N03/
data/raw/**/*.xml
data/temp/**/*.xml

# ─── 公開対象外ファイル ────────────────────────────────
# 学会抄録（非公開）
04_Manuscripts/JSph85_abstracts/

# 旧バージョン・中間 DOCX（*コピー* / 日付旧版 / コメント版）
04_Manuscripts/*コピー*.docx
04_Manuscripts/*コピー*.pdf
04_Manuscripts/17How_*.docx
04_Manuscripts/How_Outcome_Definition_Changes_Ecological_Inference_20260616*
04_Manuscripts/How_Outcome_Definition_Changes_Ecological_Inference_20260617*
